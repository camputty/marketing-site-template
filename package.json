{
  "name": "agent-native-marketing-site-starter",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "A brand-neutral, agent-native marketing site starter.",
  "engines": {
    "node": ">=24.11.0 <25"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/validate-content.ts && next build",
    "build:vercel": "tsx scripts/check-readiness.ts --vercel && tsx scripts/validate-content.ts && next build",
    "build:production": "tsx scripts/check-readiness.ts --production && tsx scripts/validate-content.ts && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate": "tsx scripts/validate-content.ts",
    "readiness": "tsx scripts/check-readiness.ts",
    "content:new": "tsx scripts/create-content.ts",
    "content:id": "tsx scripts/create-id.ts",
    "check": "eslint . && tsc --noEmit && vitest run && tsx scripts/validate-content.ts && next build"
  },
  "dependencies": {
    "gray-matter": "4.0.3",
    "marked": "18.0.5",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "2.17.5",
    "ulid": "3.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
